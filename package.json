{
	"name": "@xuranxys/cli",
	"version": "1.0.2",
	"author": "xuran",
	"repository": {
		"type": "git",
		"url": "https://github.com/the-xuran/cli.git"
	},
	"devDependencies": {
		"@changesets/cli": "^2.30.0",
		"@inquirer/prompts": "^7.10.1",
		"@types/fs-extra": "^11.0.4",
		"@types/node": "^24.12.2",
		"chalk": "^5.6.2",
		"commander": "^14.0.3",
		"fs-extra": "^11.3.4",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"ora": "^7.0.1",
		"prettier": "^3.8.2",
		"tsdown": "^0.14.2"
	},
	"bin": {
		"xuran": "dist/index.js"
	},
	"description": "the xuran cli",
	"engines": {
		"bun": ">=1.2.0"
	},
	"files": [
		"dist",
		"config"
	],
	"keywords": [
		"cli",
		"xuran"
	],
	"license": "MIT",
	"lint-staged": {
		"*.{js,ts,md}": [
			"prettier --write --config .prettierrc.json --ignore-path .prettierignore",
			"git add -u"
		]
	},
	"scripts": {
		"build": "tsdown -c tsdown.config.ts",
		"watch": "tsdown -c tsdown.config.ts -w",
		"format": "prettier \"./src/**/*.{js,jsx,ts,tsx,vue}\" --write",
		"publish": "bun publish --access=public",
		"prepare": "husky",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "changeset publish",
		"prepublishOnly": "bun run build"
	},
	"dependencies": {
		"create-tsdown": "^0.21.7",
		"create-vite": "^9.0.4"
	},
	"main": "./dist/index.js",
	"exports": {
		".": "./dist/index.js",
		"./package.json": "./package.json"
	}
}
