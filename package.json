{
	"name": "@xuranxys/cli",
	"version": "1.0.2",
	"description": "the xuran cli",
	"bin": {
		"xuran": "dist/index.js"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/the-xuran/cli.git"
	},
	"files": [
		"dist",
		"templates",
		"copy"
	],
	"engines": {
		"bun": ">=1.2.0"
	},
	"scripts": {
		"build": "tsdown -c tsdown.config.ts",
		"watch": "tsdown -c tsdown.config.ts -w",
		"format": "prettier \"./src/**/*.{js,jsx,ts,tsx,vue}\" --write",
		"publish": "bun publish --access=public",
		"prepare": "husky"
	},
	"keywords": [
		"cli",
		"xuran"
	],
	"author": "xuran",
	"license": "MIT",
	"lint-staged": {
		"*.{js,ts,md}": [
			"prettier --write --config .prettierrc.json --ignore-path .prettierignore",
			"git add -u"
		]
	},
	"devDependencies": {
		"@inquirer/prompts": "^7.10.1",
		"@types/fs-extra": "^11.0.4",
		"@types/node": "^24.12.2",
		"chalk": "^5.6.2",
		"commander": "^14.0.3",
		"fs-extra": "^11.3.4",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"ora": "^7.0.1",
		"prettier": "^3.8.2",
		"tsdown": "^0.14.2"
	}
}
